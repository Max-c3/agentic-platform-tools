      ],
      "description": "Audit hire coverage quality and data completeness from Ashby. Returns diagnostics, confidence, and aggregate missing-field signals.",
      "display_name": "Audit Hire Coverage",
      "examples": [
        "sample_size=50",
        "sample_size=100, filters={technical_only:true}",
        "sample_size=25, require_fields=['candidate_id','email']"
      ],
      "function_name": "run",
      "input_schema": {
        "$defs": {
          "Filters": {
            "properties": {
              "candidate_ids": {
                "items": {
                  "type": "string"
                },
                "title": "Candidate Ids",
                "type": "array"
              },
              "department_ids": {
                "items": {
                  "type": "string"
                },
                "title": "Department Ids",
                "type": "array"
              },
              "keywords": {
                "items": {
                  "type": "string"
                },
                "title": "Keywords",
                "type": "array"
              },
              "location_ids": {
                "items": {
                  "type": "string"
                },
                "title": "Location Ids",
                "type": "array"
              },
              "status": {
                "items": {
                  "const": "hired",
                  "type": "string"
                },
                "title": "Status",
                "type": "array"
              },
              "technical_only": {
                "default": false,
                "title": "Technical Only",
                "type": "boolean"
              }
            },
            "title": "Filters",
            "type": "object"
          }
        },
        "properties": {
          "filters": {
            "$ref": "#/$defs/Filters"
          },
          "max_scan_pages": {
            "anyOf": [
              {
                "maximum": 200,
                "minimum": 1,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Max Scan Pages"
          },
          "require_fields": {
            "items": {
              "enum": [
                "candidate_id",
                "name",
                "email",
                "linkedin",
                "job_title",
                "status",
                "hired_at",
                "created_at",
                "updated_at",
                "department_id",
                "location_id"
              ],
              "type": "string"
            },
            "title": "Require Fields",
            "type": "array"
          },
          "sample_size": {
            "default": 50,
            "maximum": 200,
            "minimum": 1,
            "title": "Sample Size",
            "type": "integer"
          }
        },
        "title": "Input",
        "type": "object"
      },
      "integration": "ashby",
      "is_write": false,
      "output_schema": {
        "$defs": {
          "Coverage": {
            "properties": {
              "by_department": {
                "additionalProperties": {
                  "type": "integer"
                },
                "title": "By Department",
                "type": "object"
              },
              "by_location": {
                "additionalProperties": {
                  "type": "integer"
                },
                "title": "By Location",
                "type": "object"
              },
              "missing_email_count": {
                "title": "Missing Email Count",
                "type": "integer"
              },
              "missing_linkedin_count": {
                "title": "Missing Linkedin Count",
                "type": "integer"
              },
              "returned_count": {
                "title": "Returned Count",
                "type": "integer"
              },
              "sample_size": {
                "title": "Sample Size",
                "type": "integer"
              }
            },
            "required": [
              "sample_size",
              "returned_count",
              "missing_email_count",
              "missing_linkedin_count",
              "by_department",
              "by_location"
            ],
            "title": "Coverage",
            "type": "object"
          }
        },
        "properties": {
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "coverage": {
            "$ref": "#/$defs/Coverage"
          },
          "diagnostics": {
            "additionalProperties": true,
            "title": "Diagnostics",
            "type": "object"
          },
          "sample_hires": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Sample Hires",
            "type": "array"
          }
        },
        "required": [
          "diagnostics",
          "coverage",
          "confidence",
          "sample_hires"
        ],
        "title": "Output",
        "type": "object"
      },
      "owner": "recruiting-platform",
      "side_effects": "None",
