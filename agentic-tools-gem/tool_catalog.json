      "approval_class": "checkpoint_high",
      "common_failures": [
        "candidate_not_found"
      ],
      "description": "Add a note to a Gem candidate profile.",
      "display_name": "Add Candidate Note",
      "examples": [
        "candidate_id='c1', note='Strong fit'"
      ],
      "function_name": "run",
      "input_schema": {
        "properties": {
          "candidate_id": {
            "minLength": 1,
            "title": "Candidate Id",
            "type": "string"
          },
          "note": {
            "minLength": 1,
            "title": "Note",
            "type": "string"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "User Id"
          }
        },
        "required": [
          "candidate_id",
          "note"
        ],
        "title": "Input",
        "type": "object"
      },
      "integration": "gem",
      "is_write": true,
      "output_schema": {
        "properties": {
          "candidate_id": {
            "title": "Candidate Id",
            "type": "string"
          },
          "note": {
            "title": "Note",
            "type": "string"
          },
          "provider_response": {
            "additionalProperties": true,
            "title": "Provider Response",
            "type": "object"
          },
          "user_id": {
            "default": "",
            "title": "User Id",
            "type": "string"
          }
        },
        "required": [
          "candidate_id",
          "note"
        ],
        "title": "Output",
        "type": "object"
      },
      "owner": "recruiting-platform",
      "side_effects": "Writes a note to Gem candidate profile.",
      "source_path": "app/tools/gem/actions/add_candidate_note.py",
      "tool_id": "gem.add_candidate_note",
      "version": "2.1.0"
    },
